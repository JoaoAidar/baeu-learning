PORT=3001
NODE_ENV=development

# Better Auth (https://better-auth.com)
# Generate the secret via: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes-random
# Public origin of THIS backend (used to mint cookie domain + OAuth redirects).
# Dev: http://localhost:3001
# Prod: https://baeu-backend-production.up.railway.app
BETTER_AUTH_URL=http://localhost:3001

# Static admin token for operator tooling. Optional. Empty = disabled.
ADMIN_TOKEN=dev-admin

# Allowed frontend origins (comma-separated). Production must set this.
# Production frontend: https://baeu-learning.vercel.app
# Also passed to Better Auth as trustedOrigins.
CORS_ORIGIN=

# Postgres connection. Leave empty to use the in-memory store (dev only).
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/baeu?sslmode=require
DATABASE_URL=

# Google OAuth (optional). Both must be set together or neither.
# Leave empty to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_ROTATED_AT=

# Email (transactional). If unset, password-reset emails are logged to stdout
# instead of being sent. The default sender is Resend's universal test sender;
# set EMAIL_FROM once you verify a domain on resend.com.
RESEND_API_KEY=
EMAIL_FROM=Baeu <onboarding@resend.dev>

# LLM exercise generator (OpenRouter or compatible). Empty = /admin/exercises/generate disabled.
# ATENÇÃO OPERACIONAL:
# presença de LLM_API_KEY/RESEND_API_KEY/DATABASE_URL só prova nomes no runtime.
# Não prova cap de gasto, geração admin, entrega de email, nem persistência SRS.
# Rode `npm run smoke:provider-contract` para o dry-run de contrato e preserve
# prod-smoke separado para o caminho learner real.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=anthropic/claude-3.5-sonnet

# Observabilidade (OpenTelemetry -> Grafana Tempo). No-op sem endpoint.
OTEL_SERVICE_NAME=baeu-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Rotacao operacional. Nao reutilizar BETTER_AUTH_SECRET como webhook/API token.
BETTER_AUTH_SECRET_ROTATED_AT=
ADMIN_TOKEN_ROTATED_AT=
