{
  "annotations": {
    "list": []
  },
  "description": "Baeu Learning backend/web overview. Uses Grafana Cloud span metrics, Loki logs and Tempo traces. Data appears after OTLP credentials are active in Railway/Vercel.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "schemaVersion": 39,
  "tags": [
    "baeu",
    "otel",
    "kairos"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Baeu Learning - Overview",
  "uid": "baeu-learning-overview",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "query": "baeu-backend,baeu-learning-api,baeu-learning-web",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "route",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        },
        "query": "label_values(traces_spanmetrics_calls_total{service_name=~\"$service\"}, span_name)",
        "label": "Route",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Golden Signals",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Request rate by service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        }
      },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate by service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / clamp_min(sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])), 0.0001)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "p50 {{service_name}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "p95 {{service_name}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "p99 {{service_name}}",
          "refId": "C"
        }
      ]
    },
    {
      "type": "row",
      "title": "Per-route Breakdown",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "Top routes by request rate",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        }
      },
      "targets": [
        {
          "expr": "topk(15, sum by (service_name, span_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\", span_name=~\"$route\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top routes by p95 latency",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        }
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by (le, service_name, span_name) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$service\", span_name=~\"$route\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Logs And Traces",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "title": "Recent errors and warnings",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-logs"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"} |~ \"(?i)error|exception|failed|warn|unauthorized\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Trace search",
      "type": "traces",
      "datasource": {
        "type": "tempo",
        "uid": "grafanacloud-traces"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "targets": [
        {
          "query": "{ resource.service.name =~ \"$service\" }",
          "queryType": "traceql",
          "refId": "A",
          "limit": 20
        }
      ]
    }
  ]
}
